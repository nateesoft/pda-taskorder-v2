	<queryString>
		<![CDATA[select emp.name empname ,bl.*,sum(r_total) total,sum(r_quan) qty from balance bl inner join employ emp on bl.r_emp = emp.code where r_table=($P{tableNo}) and r_void<>'V' and PDAPrintChekItemStation='N' group by r_plucode order by r_normal,r_etd,r_index]]>
	</queryString>
